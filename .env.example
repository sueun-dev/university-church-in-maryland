# Flask session signing key (generate a strong random string for production)
FLASK_SECRET_KEY=change-me

# SQLAlchemy database URI
# Local SQLite default: sqlite:///instance/app.db
# PostgreSQL (Cloud SQL): postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///instance/app.db

# Admin / pastor credentials (used by Basic Auth and login flow)
UPLOAD_USERNAME=admin
UPLOAD_PASSWORD=change-me
